name: "🚀 个人修正：国内 App 与 Apple 全家桶"
desc: |-
  修复小红书图片加载、通义千问无法访问、Apple 国内服务 (含 Music) 加速。
  优先级高于主配置，确保国内流量走 DIRECT。
author: "Gemini Assistant"
icon: "https://raw.githubusercontent.com/clash-verge-rev/clash-verge-rev/main/src/assets/icons/apple-logo.png"
date: "2026-03-26 16:00:00"
version: "1.2.0"

rules:
  # > Apple 中国区服务（App Store, iCloud, 系统更新）
  - DOMAIN-SUFFIX,apple.com,DIRECT
  - DOMAIN-SUFFIX,icloud.com,DIRECT
  - DOMAIN-SUFFIX,mzstatic.com,DIRECT
  - DOMAIN-SUFFIX,itunes.apple.com,DIRECT
  - DOMAIN-SUFFIX,apple-cloudkit.com,DIRECT
  - DOMAIN-SUFFIX,aaplimg.com,DIRECT
  - DOMAIN-SUFFIX,cdn-apple.com,DIRECT
  - DOMAIN-SUFFIX,digicert.com,DIRECT
  - DOMAIN-KEYWORD,apple-support,DIRECT

  # > Apple Music 加速 (修复切歌卡顿、封面显示慢)
  - DOMAIN-SUFFIX,music.apple.com,DIRECT
  - DOMAIN-SUFFIX,itunes.com,DIRECT
  - DOMAIN-KEYWORD,apple-music,DIRECT
  - DOMAIN-KEYWORD,audio-ak-spotify,DIRECT # 部分旧版音乐资源引用

  # > 小红书 (Xiaohongshu)
  - DOMAIN-SUFFIX,xiaohongshu.com,DIRECT
  - DOMAIN-SUFFIX,xhsedge.com,DIRECT
  - DOMAIN-SUFFIX,xhslink.com,DIRECT
  - DOMAIN-KEYWORD,xiaohongshu,DIRECT

  # > 通义千问 (Qwen / Alibaba AI)
  - DOMAIN-SUFFIX,qianwen.ai,DIRECT
  - DOMAIN-SUFFIX,alibabacloud.com,DIRECT
  - DOMAIN-SUFFIX,aliyuncs.com,DIRECT
  - DOMAIN-KEYWORD,qwen,DIRECT

  # > 腾讯/微信 (WeChat)
  - DOMAIN-SUFFIX,servicewechat.com,DIRECT
  - DOMAIN-SUFFIX,wechat.com,DIRECT
  - DOMAIN-SUFFIX,tencent.com,DIRECT
  - DOMAIN-SUFFIX,qq.com,DIRECT

  # > 阿里/淘宝 (Alibaba / Taobao / Amap)
  - DOMAIN-SUFFIX,taobao.com,DIRECT
  - DOMAIN-SUFFIX,tmall.com,DIRECT
  - DOMAIN-SUFFIX,alicdn.com,DIRECT
  - DOMAIN-SUFFIX,amap.com,DIRECT

  # > 字节/抖音 (ByteDance / Douyin)
  - DOMAIN-SUFFIX,snssdk.com,DIRECT
  - DOMAIN-SUFFIX,amemv.com,DIRECT
  - DOMAIN-SUFFIX,byteintl.com,DIRECT

  # > 其他常用国内修正 (京东, 百度, 拼多多, 美团, 12306)
  - DOMAIN-SUFFIX,jd.com,DIRECT
  - DOMAIN-SUFFIX,pinduoduo.com,DIRECT
  - DOMAIN-SUFFIX,baidu.com,DIRECT
  - DOMAIN-SUFFIX,meituan.com,DIRECT
  - DOMAIN-SUFFIX,12306.cn,DIRECT

  # > 局域网与本地地址直连
  - IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
  - IP-CIDR,10.0.0.0/8,DIRECT,no-resolve
  - IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
  - IP-CIDR,127.0.0.0/8,DIRECT,no-resolve

